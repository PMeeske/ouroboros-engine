!(bind! orchestrator_name "MettaCodebaseOrchestrator")
!(bind! orchestrator_mission "Split large codebases into coherent, bounded worker packages that small LLMs can execute in isolation and report back to a higher-level orchestrator.")
!(bind! chunking_policy "Prefer chunks that fit in a small-model context window, preserve local cohesion, and minimize cross-chunk coordination.")
!(bind! worker_contract "Each worker gets a narrow file scope, a local goal, an explicit MCP/tool scope, and a structured state payload to return.")
!(bind! merge_contract "The orchestrator merges worker states, resolves blockers, and decides the next wave using symbolic policy before handing a summary to the main backend model.")

!(bind! split_strategy "hybrid")
!(bind! default_worker_kind "editor")
!(bind! default_mcp_scope "repo-readonly")
!(bind! orchestrator_next_step "dispatch-next-wave")
!(bind! plan_summary "")

(= (decide-split-strategy monorepo large high) "directory-first")
(= (decide-split-strategy monorepo $size $coupling) "hybrid")
(= (decide-split-strategy service large high) "dependency-first")
(= (decide-split-strategy service $size $coupling) "hybrid")
(= (decide-split-strategy library small $coupling) "module-first")
(= (decide-split-strategy $shape $size $coupling) "hybrid")

(= (decide-worker-kind mapping $size $coupling) "mapper")
(= (decide-worker-kind docs $size $coupling) "documenter")
(= (decide-worker-kind testing $size $coupling) "tester")
(= (decide-worker-kind mcp $size $coupling) "mcp-operator")
(= (decide-worker-kind refactor large high) "surgeon")
(= (decide-worker-kind $goal $size $coupling) "editor")

(= (decide-mcp-scope mapper $goal) "repo-readonly")
(= (decide-mcp-scope documenter $goal) "repo-readonly")
(= (decide-mcp-scope tester $goal) "repo+tests")
(= (decide-mcp-scope surgeon $goal) "repo+tests")
(= (decide-mcp-scope mcp-operator $goal) "repo+tests+servers")
(= (decide-mcp-scope editor mcp) "repo+tests+servers")
(= (decide-mcp-scope editor $goal) "repo+tests")

(= (decide-priority high $dependency_band) "high")
(= (decide-priority $risk high) "high")
(= (decide-priority $risk low) "normal")
(= (decide-priority $risk $dependency_band) "normal")

(= (decide-next-orchestrator-step some $remaining $merge) "resolve-blockers")
(= (decide-next-orchestrator-step none some review) "review-and-merge")
(= (decide-next-orchestrator-step none some planned) "dispatch-next-wave")
(= (decide-next-orchestrator-step none none done) "synthesize-final")
(= (decide-next-orchestrator-step none some done) "dispatch-next-wave")
(= (decide-next-orchestrator-step none $remaining $merge) "dispatch-next-wave")

(= (decide-escalation blocked high low) "split-again")
(= (decide-escalation blocked $risk $confidence) "orchestrator-review")
(= (decide-escalation done $risk $confidence) "merge")
(= (decide-escalation needs-review $risk $confidence) "review")
(= (decide-escalation in-progress $risk $confidence) "continue")
